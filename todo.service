[Unit]
Description=Todo FastAPI Service
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/todo-app/backend

ExecStart=/home/ubuntu/todo-app/backend/venv/bin/gunicorn \
          -w 4 \
          -k uvicorn.workers.UvicornWorker \
          app.main:app

Restart=always

[Install]
WantedBy=multi-user.target